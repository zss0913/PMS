# 本地开发：SQLite（无需 Docker）
DATABASE_URL="file:./dev.db"
# 生产上线：MySQL
# DATABASE_URL="mysql://root:root@localhost:3306/pms"

# JWT 密钥
JWT_SECRET="your-super-secret-jwt-key-change-in-production"

# 定时任务（自动催缴、巡检任务按周期生成等）HTTP 鉴权；生产环境必填，请求头 Authorization: Bearer <CRON_SECRET>
# CRON_SECRET="随机长字符串"
# 巡检任务 Cron：vercel.json 中 schedule 为 UTC `0 4,10,16 * * *`，对应北京时间每日 12:00、18:00、0:00

# 全平台微信小程序（与物业公司商户号分离；也可在超管「全局小程序配置」页写入数据库覆盖）
# WECHAT_MP_TENANT_APP_ID=""
# WECHAT_MP_TENANT_APP_SECRET=""
# WECHAT_MP_STAFF_APP_ID=""
# WECHAT_MP_STAFF_APP_SECRET=""
