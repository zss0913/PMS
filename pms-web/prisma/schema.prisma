// 商业写字楼物业管理系统 - 数据库模型
// 基于 PRD 需求文档设计

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ========== 系统管理 ==========

model Company {
  id        Int      @id @default(autoincrement())
  name      String
  contact   String
  phone     String
  address   String?
  appId     String?
  appSecret String?
  wechatMchId String?
  wechatMchSerialNo String?
  wechatApiV3Key String?
  wechatPrivateKeyPem String?
  status    String   @default("active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  departments     Department[]
  employees       Employee[]
  roles           Role[]
  buildings       Building[]
  rooms           Room[]
  projects        Project[]
  tenants         Tenant[]
  tenantUsers     TenantUser[]
  billRules       BillRule[]
  bills           Bill[]
  payments        Payment[]
  refunds         Refund[]
  paymentReminders PaymentReminder[]
  workOrders            WorkOrder[]
  workOrderTypes        WorkOrderType[]
  workOrderActivityLogs WorkOrderActivityLog[]
  nfcTags         NfcTag[]
  inspectionPlans InspectionPlan[]
  inspectionTasks InspectionTask[]
  inspectionRecords InspectionRecord[]
  announcements   Announcement[]
  complaints      Complaint[]
  devices         Device[]
  deviceMaintenances DeviceMaintenance[]
  accounts            Account[]
  autoReminderSetting AutoReminderSetting?
  printTemplates      PrintTemplate[]
  dictionaries   Dictionary[]
  billActivityLogs BillActivityLog[]
  billAttachments  BillAttachment[]
  tenantAppMessages TenantAppMessage[]
  tenantInviteCodes TenantInviteCode[]
  receiptIssueRecords ReceiptIssueRecord[]
  invoiceIssueRecords InvoiceIssueRecord[]
  staffNotifications StaffNotification[]
}

model Department {
  id          Int      @id @default(autoincrement())
  name        String
  parentId    Int?
  managerId   Int?
  projectIds  String?  // number[]
  buildingIds String?  // number[]
  companyId   Int
  sort        Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company  Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  parent   Department? @relation("DeptHierarchy", fields: [parentId], references: [id])
  children Department[] @relation("DeptHierarchy")
  employees Employee[]
}

model Role {
  id        Int      @id @default(autoincrement())
  name      String
  code      String
  dataScope String
  menuIds   String?
  companyId Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company   Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employees Employee[]
}

model Employee {
  id            Int      @id @default(autoincrement())
  name          String
  phone         String   @unique
  password      String
  projectId     Int?
  departmentId  Int?
  position      String
  isLeader      Boolean  @default(false)
  businessTypes String?
  roleId        Int
  companyId     Int
  status        String   @default("active")
  lastLoginAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  company    Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  department Department? @relation(fields: [departmentId], references: [id])
  role       Role       @relation(fields: [roleId], references: [id])
  project    Project?   @relation(fields: [projectId], references: [id])
  assignedWorkOrders WorkOrder[] @relation("AssignedWorkOrders")
  staffNotifications StaffNotification[]
}

// 超级管理员(跨公司)
model SuperAdmin {
  id        Int      @id @default(autoincrement())
  name      String
  phone     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ========== 基础信息 ==========

model Project {
  id         Int      @id @default(autoincrement())
  name         String
  location     String?
  area         Decimal
  greenArea    Decimal
  manager      String
  phone        String
  buildingIds  String?
  companyId    Int
  createdAt    DateTime @default(now())
  updatedAt  DateTime @updatedAt

  company   Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  buildings Building[]
  employees Employee[]
}

model Building {
  id        Int      @id @default(autoincrement())
  name      String
  area      Decimal
  manager   String
  phone     String
  location  String?
  projectId Int?
  companyId Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company   Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  project   Project?  @relation(fields: [projectId], references: [id])
  floors    Floor[]
  rooms     Room[]
  nfcTags   NfcTag[]
  inspectionPlans InspectionPlan[]
  inspectionTasks InspectionTask[]
  devices   Device[]
  tenants   Tenant[]
  bills     Bill[]
  workOrders WorkOrder[]
}

model Floor {
  id         Int      @id @default(autoincrement())
  buildingId Int
  name       String
  sort       Int      @default(0)
  area       Decimal  @default(0)
  createdAt  DateTime @default(now())

  building Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  rooms    Room[]
}

model Room {
  id            Int      @id @default(autoincrement())
  name          String
  roomNumber    String
  area          Decimal
  buildingId    Int
  floorId       Int
  type          String
  status        String
  leasingStatus String
  companyId     Int
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  building    Building  @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  floor       Floor     @relation(fields: [floorId], references: [id], onDelete: Cascade)
  company     Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  tenantRooms TenantRoom[]
  bills       Bill[]
  workOrders  WorkOrder[]

  @@unique([buildingId, roomNumber])
}

// ========== 租客管理 ==========

model Tenant {
  id            Int      @id @default(autoincrement())
  type          String   // 租客/业主
  companyName   String
  moveInDate    DateTime
  leaseStartDate DateTime
  leaseEndDate  DateTime
  buildingId    Int
  totalArea    Decimal
  companyId     Int
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  company     Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  building    Building    @relation(fields: [buildingId], references: [id])
  tenantRooms TenantRoom[]
  tenantUsers TenantUserRelation[]
  bills       Bill[]
  workOrders  WorkOrder[]
  complaints  Complaint[]
  appMessages TenantAppMessage[]
  inviteCodes TenantInviteCode[]

  @@unique([companyId, companyName])
}

model TenantRoom {
  id        Int     @id @default(autoincrement())
  tenantId  Int
  roomId    Int
  leaseArea Decimal
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  room   Room   @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@unique([tenantId, roomId])
}

model TenantUser {
  id        Int      @id @default(autoincrement())
  phone     String
  password  String
  name      String
  companyId Int
  status    String   @default("active")
  lastLoginAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  relations TenantUserRelation[]

  // 租客端账号：手机号不按物业公司唯一；同一手机号可在多个租客下各有一条记录（与 Employee 表无关）
}

model TenantUserRelation {
  id          Int   @id @default(autoincrement())
  tenantUserId Int
  tenantId    Int
  buildingId  Int
  isAdmin     Boolean @default(false)
  createdAt   DateTime @default(now())

  tenantUser TenantUser @relation(fields: [tenantUserId], references: [id], onDelete: Cascade)
  tenant     Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantUserId, tenantId])
}

/// 租客端应用内消息（催缴等），由物业后台写入，租客管理员在小程序查看
model TenantAppMessage {
  id          Int      @id @default(autoincrement())
  tenantId    Int
  companyId   Int
  title       String
  content     String
  billIdsJson String   @default("[]")
  createdAt   DateTime @default(now())

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt])
  @@index([companyId])
}

/// 租客管理员生成的一次性邀请码，新成员凭码绑定手机号后加入对应租客主体
model TenantInviteCode {
  id                    Int       @id @default(autoincrement())
  code                  String    @unique
  tenantId              Int
  companyId             Int
  createdByTenantUserId Int?
  expiresAt             DateTime?
  usedAt                DateTime?
  usedByTenantUserId    Int?
  createdAt             DateTime  @default(now())

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([companyId])
}

// Building 需要添加 tenants 关联
// 在 Building 中通过 Tenant.buildingId 已关联

// ========== 收费管理 ==========

model Account {
  id            Int      @id @default(autoincrement())
  name          String
  bankName      String
  accountNumber String
  accountHolder String?  // 开户名称
  companyId     Int
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  company   Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  billRules BillRule[]
  bills     Bill[]
}

model AutoReminderSetting {
  id        Int      @id @default(autoincrement())
  isEnabled Boolean  @default(false)
  sendDay   Int      @default(1)   // 每月几号发送
  sendTime  String   @default("09:00") // 发送时间 HH:mm
  /// 上次自动催缴已执行的公历月份（上海时区 YYYY-MM），用于每月只发一次
  lastAutoReminderMonth String?
  companyId Int      @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model BillRule {
  id                 Int      @id @default(autoincrement())
  name               String
  code               String
  feeType            String
  amount             Decimal  // 每平米应收金额(元/㎡)
  discountRate       Decimal  @default(0)
  discountAmount     Decimal  @default(0)
  dueDateOffsetDays  Int      @default(0) // 应收日期：相对账期结束日提前/延后天数，正数=延后，负数=提前
  tenantIds          String?
  buildingIds        String?
  roomIds            String?
  periodStartDate    DateTime
  periodEndDate      DateTime
  accountId          Int
  companyId          Int
  status             String   @default("active")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  account Account @relation(fields: [accountId], references: [id])
  bills   Bill[]
}

model Bill {
  id                Int      @id @default(autoincrement())
  code              String   @unique
  /// 规则生成账单必填；手工账单可为空
  ruleId            Int?
  ruleName          String
  projectId         Int?
  /// 手工账单可无关联楼宇/房源
  buildingId        Int?
  roomId            Int?
  tenantId          Int
  feeType           String
  period            String
  accountReceivable Decimal
  amountPaid        Decimal  @default(0)
  amountDue         Decimal
  status            String   @default("open")
  paymentStatus     String
  dueDate           DateTime
  accountId         Int
  remark            String?
  companyId         Int
  /// 已开具收据的累计金额（元），不超过已缴；用于避免重复开收据
  receiptIssuedAmount Decimal @default(0)
  /// 已开具发票的累计金额（元），不超过应收；用于避免超额开票
  invoiceIssuedAmount Decimal @default(0)
  /// 总量（选填；手工账单可录）
  quantityTotal     Decimal?
  /// 单价（元，选填；手工账单可录）
  unitPrice         Decimal?
  /// rule=规则生成, manual=手工新建, work_order_fee=工单待租客确认费用时自动生成
  billSource        String   @default("rule")
  /// 关联工单（工单费用账单）
  workOrderId       Int?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  company  Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  tenant   Tenant   @relation(fields: [tenantId], references: [id])
  building Building? @relation(fields: [buildingId], references: [id])
  room     Room?     @relation(fields: [roomId], references: [id])
  account  Account  @relation(fields: [accountId], references: [id])
  rule     BillRule? @relation(fields: [ruleId], references: [id])
  workOrder WorkOrder? @relation(fields: [workOrderId], references: [id], onDelete: SetNull)
  payments PaymentBill[]
  refunds  Refund[]
  activityLogs BillActivityLog[]
  attachments BillAttachment[]
  onlineCheckoutPayments Payment[] @relation("BillOnlineCheckout")

  @@index([companyId, workOrderId])
}

/// 收据开具记录：每生成一张物理收据（Word 中一页/一份）一条；多账单合并开一张仍是一条
model ReceiptIssueRecord {
  id              Int      @id @default(autoincrement())
  companyId       Int
  /// 同一次「生成并下载」中的多条收据共享
  batchId         String
  tenantId        Int
  tenantName      String
  mergeMode       String
  billCount       Int
  totalAmount     Decimal
  billIdsJson     String
  billCodesJson   String
  lineAmountsJson String
  templateId      Int?
  operatorId      Int?
  operatorName    String?
  operatorPhone   String?
  createdAt       DateTime @default(now())
  /// 作废时间；非空表示该条收据记录已作废，对应金额已从各账单已开收据中冲回
  voidedAt              DateTime?
  voidedOperatorId      Int?
  voidedOperatorName    String?

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, createdAt])
  @@index([companyId, batchId])
}

/// 开票记录：仅系统内登记金额，无 Word 载体；同一次提交中多张「发票」共享 batchId
model InvoiceIssueRecord {
  id              Int      @id @default(autoincrement())
  companyId       Int
  batchId         String
  tenantId        Int
  tenantName      String
  mergeMode       String
  billCount       Int
  totalAmount     Decimal
  billIdsJson     String
  billCodesJson   String
  lineAmountsJson String
  operatorId      Int?
  operatorName    String?
  operatorPhone   String?
  createdAt       DateTime @default(now())
  voidedAt              DateTime?
  voidedOperatorId      Int?
  voidedOperatorName    String?
  reversedAt            DateTime?
  reversedOperatorId    Int?
  reversedOperatorName  String?

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, createdAt])
  @@index([companyId, batchId])
}

/// 账单附件（图片 / PDF / Office / 表格等），不记入操作日志
model BillAttachment {
  id           Int      @id @default(autoincrement())
  billId       Int
  companyId    Int
  originalName String
  storedName   String
  mimeType     String
  sizeBytes    Int
  createdAt    DateTime @default(now())

  bill    Bill    @relation(fields: [billId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([billId])
  @@index([companyId, billId])
}

/// 账单操作日志：增删改、缴费、退费、生成催缴单/收据、催缴记录等
model BillActivityLog {
  id             Int      @id @default(autoincrement())
  billId         Int?
  billCode       String
  companyId      Int
  action         String
  summary        String?
  changesJson    String?
  operatorId     Int?
  operatorName   String?
  operatorPhone  String?
  metaJson       String?
  createdAt      DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  bill    Bill?   @relation(fields: [billId], references: [id], onDelete: SetNull)

  @@index([companyId, billId])
  @@index([companyId, billCode])
}

model Payment {
  id             Int      @id @default(autoincrement())
  code           String   @unique
  tenantId       Int
  paidAt         DateTime
  payer          String
  totalAmount    Decimal
  paymentMethod  String
  /// success | pending | cancelled | failed
  paymentStatus  String
  transactionId  String?
  /// 线下记账为员工；租客线上自助缴费可为空
  operatorId     Int?
  companyId      Int
  /// 租客端「工单费用」在线支付：下单时关联待缴账单，支付成功前为 pending
  relatedBillId  Int?
  /// 租客端多笔账单合并支付：pending 阶段存账单 ID 列表 JSON（number[]），成功入账后清空语义由业务保证
  pendingBillIdsJson String?
  createdAt      DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  bills   PaymentBill[]
  relatedBill Bill? @relation("BillOnlineCheckout", fields: [relatedBillId], references: [id], onDelete: SetNull)

  @@index([companyId, relatedBillId])
}

model PaymentBill {
  id             Int     @id @default(autoincrement())
  paymentId      Int
  billId         Int
  billCode       String
  amount         Decimal
  amountDueBefore Decimal
  amountDueAfter  Decimal
  createdAt      DateTime @default(now())

  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  bill    Bill    @relation(fields: [billId], references: [id], onDelete: Cascade)
}

model Refund {
  id         Int      @id @default(autoincrement())
  code       String   @unique
  billId     Int
  tenantId   Int
  refundAt   DateTime
  refunder   String
  operatorId Int
  amount     Decimal
  reason     String
  remark     String?
  companyId  Int
  createdAt  DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  bill    Bill    @relation(fields: [billId], references: [id], onDelete: Cascade)
}

model PaymentReminder {
  id             Int      @id @default(autoincrement())
  code           String   @unique
  billIds        String
  method         String
  content        String?
  notifyTargetId Int
  status         String
  sentAt         DateTime
  operatorId     Int
  companyId      Int
  createdAt      DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

// ========== 工单管理 ==========


model WorkOrderType {
  id                    Int      @id @default(autoincrement())
  name                  String
  sort                  Int      @default(0)
  enabled               Boolean  @default(true)
  responseTimeoutHours  Int?     // 多久没有响应为超时（小时），null 表示不启用
  notifyLeaderOnTimeout Boolean  @default(false) // 超时时是否提醒组长
  companyId             Int
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model WorkOrder {
  id           Int      @id @default(autoincrement())
  code         String   @unique
  projectId    Int?
  buildingId   Int
  /// 可选：员工自建公区工单等可无房源
  roomId       Int?
  /// 可选：与 roomId 一致，可无租客主体
  tenantId     Int?
  reporterId   Int
  source       String
  type         String
  title        String
  description  String
  images       String?
  location     String?
  severity     String?
  taskId       Int?
  tagId        String?
  status       String
  /// 租客报事报修：公共设施 | 套内设施
  facilityScope         String?
  /// 套内报修时租客是否已确认费用知情
  feeNoticeAcknowledged Boolean  @default(false)
  /// 费用流程中员工填写的费用说明（处理中提交后进入「待员工确认费用」等）
  feeRemark             String?
  /// 费用合计（人民币元，须 > 0），与 feeRemark 一并提交
  feeTotal              Float?
  /// 租客确认费用后继续处理的时间
  feeConfirmedAt        DateTime?
  assignedAt   DateTime?
  assignedTo   Int?
  respondedAt  DateTime?
  completedAt  DateTime?
  evaluatedAt  DateTime?
  /// 办结进入待评价时上传的现场照片（JSON 字符串数组，与 images 格式一致）
  completionImages   String?
  /// 办结说明（选填）
  completionRemark   String?
  /// 评价说明：员工标记评价完成或租客提交评价时写入（选填）
  evaluationNote     String?
  companyId    Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  company   Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  building  Building  @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  tenant    Tenant?   @relation(fields: [tenantId], references: [id])
  room      Room?     @relation(fields: [roomId], references: [id])
  assignedEmployee Employee? @relation("AssignedWorkOrders", fields: [assignedTo], references: [id])
  activityLogs     WorkOrderActivityLog[]
  feeBills         Bill[]
}

/// 工单操作日志（创建、编辑、派单、流程节点等）
model WorkOrderActivityLog {
  id             Int      @id @default(autoincrement())
  workOrderId    Int
  workOrderCode  String
  companyId      Int
  action         String
  summary        String?
  changesJson    String?
  operatorId     Int?
  operatorName   String?
  operatorPhone  String?
  metaJson       String?
  createdAt      DateTime @default(now())

  company   Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  workOrder WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)

  @@index([companyId, workOrderId])
  @@index([companyId, workOrderCode])
}

// ========== 巡检管理 ==========

model NfcTag {
  id             Int      @id @default(autoincrement())
  tagId          String
  location       String
  description    String?
  inspectionType String
  buildingId     Int
  companyId      Int
  status         String   @default("active")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  building Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)
}

model InspectionPlan {
  id             Int      @id @default(autoincrement())
  name           String
  inspectionType String
  cycleType      String
  cycleValue     Int      @default(1)
  cycleWeekday   Int?
  cycleMonthDay  Int?
  userIds        String?
  route          String?
  checkItems     String?
  buildingId     Int?
  companyId      Int
  status         String   @default("active")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  company  Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  building Building? @relation(fields: [buildingId], references: [id], onDelete: Restrict)
  tasks    InspectionTask[]
}

model InspectionTask {
  id             Int      @id @default(autoincrement())
  code           String   @unique
  planId         Int
  planName       String
  inspectionType String
  scheduledDate  DateTime
  userIds        String?
  route          String?
  checkItems     String?
  buildingId     Int?
  status         String
  startedAt      DateTime?
  completedAt    DateTime?
  completedBy    Int?
  companyId      Int
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  company  Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  plan     InspectionPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  building Building? @relation(fields: [buildingId], references: [id], onDelete: Restrict)
  records  InspectionRecord[]
}

model InspectionRecord {
  id             Int      @id @default(autoincrement())
  taskId         Int
  taskCode       String
  inspectionType String
  tagId          String
  location       String
  checkedAt      DateTime
  checkedBy      Int
  status         String
  checkItems     String?
  companyId      Int
  createdAt      DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  task    InspectionTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
}

// ========== 公告 ==========

model Announcement {
  id          Int      @id @default(autoincrement())
  title       String
  content     String
  images      String?
  publisherName String?
  publisherId Int?
  scope       String
  buildingIds  String?
  publishTime DateTime?
  status      String
  readCount   Int      @default(0)
  companyId   Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

/// 员工站内业务通知（报事报修/巡检/吐槽等），按楼宇+管理业务类型投递
model StaffNotification {
  id         Int       @id @default(autoincrement())
  companyId  Int
  employeeId Int
  category   String
  title      String
  summary    String?
  entityType String
  entityId   Int
  buildingId Int?
  readAt     DateTime?
  createdAt  DateTime  @default(now())

  company  Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([companyId, category, entityType, entityId, employeeId])
  @@index([companyId, employeeId, createdAt])
}

// ========== 卫生吐槽 ==========

model Complaint {
  id          Int      @id @default(autoincrement())
  projectId   Int?
  buildingId  Int
  tenantId    Int
  reporterId  Int
  location    String
  description String
  images      String?
  status      String
  assignedTo  Int?
  handledBy   Int?
  handledAt   DateTime?
  result      String?
  resultImages String?
  companyId   Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  tenant  Tenant @relation(fields: [tenantId], references: [id])
}

// ========== 设备 ==========

model Device {
  id                 Int      @id @default(autoincrement())
  code               String
  name               String
  type               String
  location           String   @default("")
  buildingId         Int
  commissionedDate   DateTime
  supplier           String   @default("")
  contactPhone       String?
  maintenanceContact String?
  brand              String?
  tagId              String?
  status             String
  companyId          Int
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  building    Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  maintenances DeviceMaintenance[]

  @@unique([companyId, code])
}

model DeviceMaintenance {
  id           Int      @id @default(autoincrement())
  code         String
  deviceId     Int
  type         String
  date         DateTime
  maintainerId Int
  cost         Decimal  @default(0)
  content      String
  images       String?
  remark       String?
  companyId    Int
  createdAt    DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  device  Device  @relation(fields: [deviceId], references: [id], onDelete: Cascade)
}

// ========== 系统配置 ==========

model PrintTemplate {
  id         Int      @id @default(autoincrement())
  name       String
  type       String
  templateUrl String?
  fields     String?
  companyId  Int
  status     String   @default("active")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model Dictionary {
  id        Int      @id @default(autoincrement())
  type      String
  name      String
  value     String
  sort      Int      @default(0)
  companyId Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
}
